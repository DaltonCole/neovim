{
    "suggest.noselect": true,
    "languageserver": {
      "ccls": {
        "command": "ccls",
        "filetypes": ["c", "cc", "cpp", "c++", "objc", "objcpp", "cu"],
        "rootPatterns": [".ccls", "compile_commands.json", ".git/", ".hg/"],
        "initializationOptions": {
            "cache": {
              "directory": "/tmp/ccls"
            },
            "highlight": {
                "lsRanges": true
            }
          }
      }
    }
}
